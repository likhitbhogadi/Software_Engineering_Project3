# Shared across all services — MUST be identical in each service's .env
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Auth Service
AUTH_PORT=5001
AUTH_MONGO_URI=mongodb://localhost:27017/auth_db

# Sync Service
SYNC_PORT=5002
SYNC_MONGO_URI=mongodb://localhost:27017/sync_db
WRITE_SERVICE_URL=http://localhost:5003

# Write Service
WRITE_PORT=5003
WRITE_MONGO_URI=mongodb://localhost:27017/patient_write_db

# Read Service
READ_PORT=5004
READ_MONGO_URI=mongodb://localhost:27017/patient_read_db
REDIS_URI=redis://localhost:6379
